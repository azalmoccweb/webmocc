<!doctype html>
<html lang="az">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0d4d95" />
    <title><%= title ? `${title} • ${appName}` : appName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet">
  </head>
  <body class="<%= user ? 'app-shell' : 'login-shell' %>">
    <% if (user) { %>
      <nav class="app-navbar navbar navbar-expand-xl navbar-light sticky-top">
        <div class="container-fluid app-navbar__inner px-3 px-lg-4">
          <a class="navbar-brand brand-lockup" href="/">
            <span class="brand-lockup__logo-wrap">
              <img src="/assets/airline-mark.png" alt="Azerbaijan Airlines" class="brand-lockup__logo" />
            </span>
            <span class="brand-lockup__meta">
              <span class="brand-lockup__title"><%= appName %></span>
              <span class="brand-lockup__subtitle">Azerbaijan Airlines</span>
            </span>
          </a>

          <button class="navbar-toggler app-navbar__toggle border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>

          <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav nav-pills-custom mx-auto mt-3 mt-xl-0 mb-3 mb-xl-0">
              <li class="nav-item"><a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">Dashboard</a></li>
              <li class="nav-item"><a class="nav-link <%= currentPath.startsWith('/requests') ? 'active' : '' %>" href="/requests">Requests</a></li>
              <% if (user.role === 'admin') { %>
                <li class="nav-item"><a class="nav-link <%= currentPath.startsWith('/settings') ? 'active' : '' %>" href="/settings">Settings</a></li>
              <% } %>
            </ul>

            <div class="nav-actions ms-xl-3 mt-3 mt-xl-0">
              <div class="user-chip">
                <div class="user-chip__eyebrow"><%= user.role %></div>
                <div class="user-chip__name"><%= user.name %></div>
              </div>
              <form action="/logout" method="post">
                <button class="btn btn-outline-brand btn-sm px-3 py-2">Logout</button>
              </form>
            </div>
          </div>
        </div>
      </nav>
    <% } %>

    <main class="<%= user ? 'app-main container-fluid px-3 px-lg-4 pb-4 pb-lg-5' : 'login-main' %>">
      <% if (flash) { %>
        <div class="alert app-alert alert-<%= flash.type %>"><%= flash.message %></div>
      <% } %>
      <%- body %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/app.js"></script>
  </body>
</html>
